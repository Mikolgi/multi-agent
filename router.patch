+    def _next_route_node(self, state: AgentState) -> str:
+        route = state.get("route") or DEFAULT_FULL_ROUTE
+        route_index = state.get("route_index", 0)
+        if route_index >= len(route):
+            return ROUTE_END
+        next_node = route[route_index]
+        if next_node not in ALLOWED_ROUTE_NODES:
+            return ROUTE_END
+        return next_node
+
+    @staticmethod
+    def _advance_route(state: AgentState, **updates: object) -> dict[str, object]:
+        if "route" in state:
+            updates["route_index"] = state.get("route_index", 0) + 1
+        return updates
+
+    def _parse_route_decision(self, raw_output: str, state: AgentState) -> RouteDecision:
+        try:
+            payload = self._extract_json_object(raw_output)
+            route = payload.get("route", [])
+            reason = str(payload.get("reason") or "Supervisor выбрал маршрут по запросу.").strip()
+            risks_value = payload.get("risks", [])
+            risks = [str(item).strip() for item in risks_value if str(item).strip()] if isinstance(risks_value, list) else []
+            route = self._normalize_route(route)
+            route = self._validate_route(route=route, state=state)
+            if not route:
+                raise ValueError("empty route")
+            return RouteDecision(route=route, reason=reason, risks=risks, raw_output=raw_output)
+        except Exception:
+            fallback = self._fallback_route(state)
+            return RouteDecision(
+                route=fallback,
+                reason="Supervisor вернул невалидный JSON или некорректный route, поэтому применен безопасный fallback-маршрут.",
+                risks=["Маршрут выбран fallback-логикой, стоит проверить supervisor output в Langfuse."],
+                raw_output=raw_output,
+            )
+
+    @staticmethod
+    def _extract_json_object(raw_output: str) -> dict:
+        text = raw_output.strip()
+        fenced = re.search(r"```(?:json)?\s*(\{.*?\})\s*```", text, flags=re.DOTALL | re.IGNORECASE)
+        if fenced:
+            text = fenced.group(1)
+        else:
+            json_object = re.search(r"\{.*\}", text, flags=re.DOTALL)
+            if json_object:
+                text = json_object.group(0)
+        payload = json.loads(text)
+        if not isinstance(payload, dict):
+            raise ValueError("Supervisor response is not a JSON object")
+        return payload
+
+    @staticmethod
+    def _normalize_route(route: object) -> list[str]:
+        if not isinstance(route, list):
+            return []
+        normalized: list[str] = []
+        for item in route:
+            key = str(item).strip().lower().replace("-", "_")
+            canonical = ROUTE_ALIASES.get(key)
+            if canonical and canonical not in normalized:
+                normalized.append(canonical)
+        return normalized
+
+    def _validate_route(self, route: list[str], state: AgentState) -> list[str]:
+        request = state["request"]
+        has_vacancy = bool(request.vacancy_text.strip())
+        validated = [node for node in route if node in ALLOWED_ROUTE_NODES]
+
+        # Без текста вакансии vacancy_matcher чаще всего будет гадать, поэтому убираем его.
+        if not has_vacancy:
+            validated = [node for node in validated if node != ROUTE_VACANCY_MATCHER]
+
+        # Если маршрут пишет резюме, но не проверяет его, добавляем critic как safety gate.
+        if ROUTE_RESUME_WRITER in validated and ROUTE_CRITIC not in validated:
+            validated.append(ROUTE_CRITIC)
+
+        # Если есть vacancy_matcher, ему полезен хотя бы анализ профиля перед сопоставлением.
+        if ROUTE_VACANCY_MATCHER in validated and ROUTE_PROFILE_ANALYZER not in validated:
+            validated.insert(0, ROUTE_PROFILE_ANALYZER)
+
+        return validated
+
+    def _fallback_route(self, state: AgentState) -> list[str]:
+        request = state["request"]
+        objective = request.objective.lower()
+        has_vacancy = bool(request.vacancy_text.strip())
+
+        critique_words = ("проверь", "оцени", "критик", "критика", "ревью", "ошиб", "риск")
+        analysis_words = ("проанализ", "извлеки", "вытащи", "факты", "навыки", "профиль")
+        match_words = ("подхожу", "соответств", "сравни", "сопостав", "match", "ваканс")
+        write_words = ("резюме", "черновик", "собери", "напиши", "адаптир", "улучши", "подправ")
+
+        wants_critique = any(word in objective for word in critique_words)
+        wants_analysis = any(word in objective for word in analysis_words)
+        wants_match = any(word in objective for word in match_words)
+        wants_write = any(word in objective for word in write_words)
+
+        if wants_critique and not wants_write and not wants_match:
+            return [ROUTE_CRITIC]
+        if wants_analysis and not wants_write and not has_vacancy:
+            return [ROUTE_PROFILE_ANALYZER]
+        if wants_match and has_vacancy and not wants_write:
+            return [ROUTE_PROFILE_ANALYZER, ROUTE_VACANCY_MATCHER, ROUTE_CRITIC]
+        if has_vacancy:
+            return [*DEFAULT_FULL_ROUTE]
+        return [ROUTE_PROFILE_ANALYZER, ROUTE_RESUME_WRITER, ROUTE_CRITIC]
+
+    @staticmethod
+    def _format_supervisor_plan(decision: RouteDecision) -> str:
+        risks = decision.risks or ["Явно не выдумывать факты, которых нет в профиле."]
+        return "\n".join(
